<!doctype html>
<html lang="en">
<head>
	<meta charset="utf-8" />
	<meta name="viewport" content="width=device-width, initial-scale=1" />
	<meta name="color-scheme" content="dark" />
	<title>@(ViewData["Title"] is string title ? $"{title} · FutureMUD" : "FutureMUD")</title>
	<meta name="description" content="FutureMUD is an engine for building roleplay-intensive text worlds." />
	<link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
	<script src="~/js/site.js" asp-append-version="true" defer></script>
	<link rel="alternate" type="application/rss+xml" title="FutureMUD news" href="/news/feed.xml" />
</head>
<body>
	<a class="skip-link" href="#main">Skip to content</a>
	<header class="site-header">
		<div class="site-header-inner">
			<a class="brand" href="/" aria-label="FutureMUD home">
				<img src="/images/fm-logo.png" width="52" height="52" alt="" />
				<span><strong>FutureMUD</strong><small>engine for living text worlds</small></span>
			</a>
			<nav class="primary-navigation" aria-label="Primary navigation">
				<a href="/about">About</a>
				<a href="/getting-started">Get started</a>
				<a href="/downloads">Downloads</a>
				<details class="nav-disclosure" data-nav-disclosure>
					<summary>Documentation</summary>
					<ul>
						<li><a href="/docs/commands"><strong>Commands</strong><small>Player, builder and staff help</small></a></li>
						<li><a href="/docs/futureprog/functions"><strong>FutureProg functions</strong><small>Built-in functions and overloads</small></a></li>
						<li><a href="/docs/futureprog/types"><strong>FutureProg types</strong><small>Dot-reference properties by type</small></a></li>
						<li><a href="/docs/futureprog/collections"><strong>Collection extensions</strong><small>Collection query and transform helpers</small></a></li>
						<li><a href="/docs/items/components"><strong>Item components</strong><small>Component blurbs and builder help</small></a></li>
						<li><a href="/patch-notes"><strong>Patch notes</strong><small>Release and website changes</small></a></li>
					</ul>
				</details>
				<a href="/news">News</a>
			</nav>
		</div>
	</header>
	<main id="main" class="page-shell">
		@RenderBody()
	</main>
	<footer>
		<p>FutureMUD and its associated tools are available under the <a href="/license">CC BY-NC-ND 3.0 license</a>.</p>
		<nav aria-label="Footer navigation">
			<a href="https://discord.gg/fyKnckr4PG">Discord support</a>
			<a href="https://github.com/FutureMUD/FutureMUD">Public source repository</a>
			<a href="/license">Licensing</a>
			<a href="/patch-notes">Patch notes</a>
			<a href="/sitemap.xml">Sitemap</a>
			<a href="/health/live">Service status</a>
		</nav>
	</footer>
</body>
</html>
